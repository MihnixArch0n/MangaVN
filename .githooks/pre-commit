#!/bin/sh
# Pre-commit hook: lintDebug + ktlintCheck + detekt khi có staged .kt files.
# Cài tự động qua Gradle task installGitHooks (chạy khi build lần đầu).

STAGED_KT=$(git diff --cached --name-only --diff-filter=ACM | grep '\.kt$')
if [ -z "$STAGED_KT" ]; then
    exit 0
fi

if [ -f "./gradlew" ]; then
    GRADLEW="./gradlew"
else
    echo "Không tìm thấy gradlew — bỏ qua kiểm tra."
    exit 0
fi

# AuthSecrets.kt bị gitignore (chứa secret thật) — tạo stub tạm nếu chưa có
# để lintDebug compile được. Xóa sau khi hook chạy xong.
AUTH_SECRETS="app/src/main/java/com/example/mybookslibrary/util/AuthSecrets.kt"
STUB_CREATED=0
if [ ! -f "$AUTH_SECRETS" ]; then
    mkdir -p "$(dirname "$AUTH_SECRETS")"
    printf 'package com.example.mybookslibrary.util\n\nobject AuthSecrets {\n    const val WEB_CLIENT_ID = "stub"\n}\n' > "$AUTH_SECRETS"
    STUB_CREATED=1
fi

echo ">>> lint + ktlint + detekt: kiểm tra staged .kt files..."

"$GRADLEW" lintDebug ktlintCheck detekt --console=plain -q
STATUS=$?

# Xóa stub nếu đã tạo (không để lại file rác trong working tree)
if [ $STUB_CREATED -eq 1 ]; then
    rm -f "$AUTH_SECRETS"
fi

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "FAILED — sửa violations rồi commit lại."
    echo "  lint:   app/build/reports/lint-results-debug.html"
    echo "  ktlint: Linux/macOS dùng './gradlew ktlintFormat' để auto-fix (không dùng trên Windows)."
    echo "  detekt: app/build/reports/detekt/detekt.html"
fi
exit $STATUS
